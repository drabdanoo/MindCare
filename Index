  <!-- Firebase + App Logic -->
  <script type="module">
    // Firebase SDKs (modular, served from CDN)
    import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js";
    import { getAuth, onAuthStateChanged, createUserWithEmailAndPassword, signInWithEmailAndPassword, signOut, updateProfile } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-auth.js";
    import { getFirestore, doc, setDoc, getDoc, addDoc, collection, serverTimestamp, query, where, orderBy, limit, getDocs } from "https://www.gstatic.com/firebasejs/11.0.1/firebase-firestore.js";

    // Your project config (fixed storageBucket)
    const firebaseConfig = {
      apiKey: "AIzaSyCWj52nov-vdKBfHQjz95B-39O19adW4T8",
      authDomain: "mindcare-9a4d2.firebaseapp.com",
      projectId: "mindcare-9a4d2",
      storageBucket: "mindcare-9a4d2.appspot.com",
      messagingSenderId: "424143354909",
      appId: "1:424143354909:web:a792439841410d69b3daf4",
      measurementId: "G-DMGTJKG75Y"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const db = getFirestore(app);

    // DOM helpers
    const $ = (id) => document.getElementById(id);
    const show = (id) => $(id).classList.remove('hidden');
    const hide = (id) => $(id).classList.add('hidden');
    const pages = ['homePage','doctorsPage','registerPage','loginPage','bookingPage','dashboardPage','sessionPage'];
    function goto(pageId){ pages.forEach(p => hide(p)); show(pageId); }

    // Fake doctors list for MVP
    const doctors = [
      { name: 'Dr. Sarah Johnson', role: 'Psychiatrist', fee: 120, avatar: '👩‍⚕️', langs: ['English','Arabic'], exp: 12, specs: ['Anxiety','Depression'] },
      { name: 'Dr. Michael Chen', role: 'Psychologist', fee: 95, avatar: '👨‍⚕️', langs: ['English'], exp: 8, specs: ['CBT','Trauma'] },
      { name: 'Lisa Rodriguez', role: 'Licensed Counselor', fee: 75, avatar: '👩‍💼', langs: ['English','Arabic'], exp: 6, specs: ['Stress','Relationships'] },
    ];

    function renderDoctors(){
      const wrap = document.querySelector('#doctorCards');
      wrap.innerHTML = '';
      doctors.forEach(d => {
        const card = document.createElement('div');
        card.className = 'bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow';
        card.innerHTML = `
          <div class="flex items-center mb-4">
            <div class="w-16 h-16 bg-blue-200 rounded-full flex items-center justify-center text-2xl">${d.avatar}</div>
            <div class="ml-4">
              <h3 class="text-xl font-semibold">${d.name}</h3>
              <p class="text-blue-600 font-medium">${d.role}</p>
            </div>
          </div>
          <div class="space-y-2 mb-4 text-sm text-gray-600">
            <p><span class="font-medium">Languages:</span> ${d.langs.join(', ')}</p>
            <p><span class="font-medium">Experience:</span> ${d.exp} years</p>
            <p><span class="font-medium">Specialties:</span> ${d.specs.join(', ')}</p>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-2xl font-bold text-green-600">$${d.fee}/session</span>
            <button data-book="${d.name}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg">Book Now</button>
          </div>`;
        wrap.appendChild(card);
      });
      wrap.querySelectorAll('[data-book]').forEach(btn => btn.addEventListener('click', () => startBooking(btn.getAttribute('data-book'))));
    }

    // Booking flow
    let selectedDoctor = null;
    function startBooking(name){
      selectedDoctor = name;
      $('#selectedDoctor').textContent = `with ${name}`;
      goto('bookingPage');
    }

    async function createAppointment(form){
      const fd = new FormData(form);
      const sessionType = fd.get('sessionType');
      const date = fd.get('date');
      const time = fd.get('time');
      const reason = fd.get('reason') || '';
      const emergency = fd.get('emergency') || '';
      if(!selectedDoctor) throw new Error('No doctor selected');
      if(!auth.currentUser) throw new Error('You must be logged in');

      await addDoc(collection(db, 'appointments'), {
        patientId: auth.currentUser.uid,
        patientEmail: auth.currentUser.email,
        doctorName: selectedDoctor,
        sessionType, date, time,
        reason, emergency,
        status: 'pending',
        createdAt: serverTimestamp()
      });
    }

    async function loadMyAppointments(){
      if(!auth.currentUser) return;
      const q = query(
        collection(db,'appointments'),
        where('patientId','==',auth.currentUser.uid),
        orderBy('date','asc'),
        limit(20)
      );
      const snap = await getDocs(q);
      const list = $('#upcomingList');
      list.innerHTML = '';
      let upcomingCount = 0;

      if(snap.empty){
        list.innerHTML = '<p class="text-gray-500">No upcoming appointments yet.</p>';
      } else {
        snap.forEach(docSnap => {
          const a = docSnap.data();
          upcomingCount++;
          const item = document.createElement('div');
          item.className = 'flex items-center justify-between p-4 border border-gray-200 rounded-lg';
          item.innerHTML = `
            <div class="flex items-center">
              <div class="w-12 h-12 bg-blue-200 rounded-full flex items-center justify-center text-xl">👨‍⚕️</div>
              <div class="ml-4">
                <p class="font-semibold">${a.doctorName}</p>
                <p class="text-sm text-gray-600">${a.sessionType?.toUpperCase()} • ${formatHumanDate(a.date)} at ${formatHumanTime(a.time)}</p>
              </div>
            </div>
            <div class="flex space-x-2">
              <button class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm">Join Session</button>
              <button class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-50">Reschedule</button>
            </div>`;
          list.appendChild(item);
        });
      }

      // Stats
      $('#statUpcoming').textContent = upcomingCount;
      $('#statCompleted').textContent = 0; // placeholder until status update implemented
      $('#statPrescriptions').textContent = 0; // placeholder
      $('#statReminders').textContent = 1; // placeholder
    }

    const formatHumanDate = (yyyyMmDd) => {
      if(!yyyyMmDd) return '';
      const [y,m,d] = yyyyMmDd.split('-').map(Number);
      return new Date(y, m-1, d).toLocaleDateString(undefined, { month:'short', day:'numeric', year:'numeric' });
    };
    const formatHumanTime = (hhmm) => {
      if(!hhmm) return '';
      const [h,m] = hhmm.split(':').map(Number);
      const date = new Date();
      date.setHours(h, m);
      return date.toLocaleTimeString(undefined, { hour:'numeric', minute:'2-digit' });
    };

    // Auth flows
    async function doRegister(e){
      e.preventDefault();
      const fd = new FormData(e.target);
      const fullName = fd.get('fullName');
      const email = fd.get('email');
      const phone = fd.get('phone');
      const dob = fd.get('dob');
      const password = fd.get('password');

      const cred = await createUserWithEmailAndPassword(auth, email, password);
      await updateProfile(cred.user, { displayName: fullName });
      await setDoc(doc(db,'users',cred.user.uid), { role:'patient', fullName, email, phone, dob, createdAt: serverTimestamp() });

      e.target.reset();
      alert('Registration successful. Welcome to MindCare.');
    }

    async function doLogin(e){
      e.preventDefault();
      const fd = new FormData(e.target);
      const email = fd.get('email');
      const password = fd.get('password');
      await signInWithEmailAndPassword(auth, email, password);
      e.target.reset();
    }

    async function doLogout(){ await signOut(auth); }

    // Nav + routing
    function wireNav(){
      document.querySelectorAll('[data-nav]')?.forEach(btn => btn.addEventListener('click', () => goto(btn.getAttribute('data-nav')+ 'Page')));
      $('#ctaFindDoctor').addEventListener('click', () => goto('doctorsPage'));
      $('#ctaJoin').addEventListener('click', () => goto('registerPage'));
      $('#navLoginBtn').addEventListener('click', () => goto('loginPage'));
      $('#navSignupBtn').addEventListener('click', () => goto('registerPage'));
      $('#navLogoutBtn').addEventListener('click', doLogout);
    }

    // Forms
    $('#registerForm').addEventListener('submit', doRegister);
    $('#loginForm').addEventListener('submit', doLogin);
    $('#bookingForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      try {
        await createAppointment(e.target);
        alert('Appointment booked successfully. You\'ll receive a confirmation email.');
        goto('dashboardPage');
        await loadMyAppointments();
      } catch(err){
        alert(err.message || 'Booking failed');
      }
    });

    // Render doctors once
    renderDoctors();

    // Auth state handler
    onAuthStateChanged(auth, async (user) => {
      const navUser = $('#navUser');
      const logoutBtn = $('#navLogoutBtn');
      const loginBtn = $('#navLoginBtn');
      const signupBtn = $('#navSignupBtn');

      if(user){
        navUser.textContent = `Signed in as ${user.displayName || user.email}`;
        navUser.classList.remove('hidden');
        logoutBtn.classList.remove('hidden');
        loginBtn.classList.add('hidden');
        signupBtn.classList.add('hidden');
        goto('dashboardPage');
        await loadMyAppointments();
      } else {
        navUser.classList.add('hidden');
        logoutBtn.classList.add('hidden');
        loginBtn.classList.remove('hidden');
        signupBtn.classList.remove('hidden');
        goto('homePage');
      }
    });

    // Reminders placeholder
    $('#btnReminders').addEventListener('click', () => {
      alert('Reminder Management (demo):\n\n• Appointment reminder enabled\n• Daily medication reminder at 8:00 AM');
    });

    // Initial route
    goto('homePage');
  </script>
</body>
</html>
