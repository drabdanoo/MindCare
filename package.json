{
  "name": "mindcare",
  "version": "1.0.0",
  "description": "Secure telemedicine platform for mental health care in Iraq",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "firebase:emulate": "firebase emulators:start",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:dev": "firebase use mindcare-dev && firebase deploy",
    "firebase:deploy:prod": "firebase use mindcare-prod && firebase deploy"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/native": "^7.1.25",
    "@react-navigation/native-stack": "^7.8.6",
    "@sentry/browser": "^10.30.0",
    "@sentry/tracing": "^7.120.4",
    "expo-constants": "^18.0.12",
    "expo-notifications": "^0.32.15",
    "firebase": "^12.6.0",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^2.4.2",
    "react-native-jitsi-meet": "^2.3.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.18.0",
    "toastify-js": "^1.12.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^4.0.15",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "firebase-tools": "^13.0.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "~5.9.2",
    "vite": "^5.0.0",
    "vitest": "^4.0.15"
  }
}
