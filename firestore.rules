rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    function signedIn() { return request.auth != null; }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid);
      allow create: if signedIn() && (uid == request.auth.uid);
      allow update: if signedIn() && (uid == request.auth.uid);
    }

    match /doctors/{uid} {
      // Only read verified doctors (or own profile if doctor)
      allow read: if resource.data.verified == true || (signedIn() && uid == request.auth.uid);
      // Doctor can create and update their own profile
      allow create: if signedIn() && uid == request.auth.uid;
      allow update: if signedIn() && uid == request.auth.uid;
    }

    match /appointments/{id} {
      allow create: if signedIn() && request.resource.data.patientId == request.auth.uid;

      // Patient can see/update their own; Doctor can see/update theirs
      allow read, update: if signedIn() && (
          resource.data.patientId == request.auth.uid ||
          resource.data.doctorId == request.auth.uid
      );

      // Optional: allow delete by patient before accepted
      allow delete: if signedIn() && resource.data.patientId == request.auth.uid && resource.data.status == 'pending';
    }
  }
}