rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    function signedIn() { return request.auth != null; }

    // Verify caller has doctor role in users collection
    function isDoctor() {
      return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    match /users/{uid} {
      allow read: if signedIn() && uid == request.auth.uid;

      // At registration: role must be 'patient' — doctors are created via admin SDK only
      allow create: if signedIn() && uid == request.auth.uid
        && request.resource.data.role == 'patient';

      // Profile updates: role field can never be changed by the user
      allow update: if signedIn() && uid == request.auth.uid
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fullName', 'name', 'phone', 'specialization', 'bio', 'updatedAt']);
    }

    match /doctors/{uid} {
      // Public read of verified doctor profiles
      allow read: if true;
      // Only the doctor updates their own profile (or you can restrict to admin later)
      allow write: if signedIn() && uid == request.auth.uid;
    }

    match /appointments/{id} {
      allow create: if signedIn() && request.resource.data.patientId == request.auth.uid;

      // Patient can see their own; Doctor can see theirs
      allow read: if signedIn() && (
          resource.data.patientId == request.auth.uid ||
          resource.data.doctorId == request.auth.uid
      );

      // Patient can only update payment-related fields
      allow update: if signedIn()
        && resource.data.patientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['paymentStatus', 'paymentMethod', 'paymentMethodName',
                      'paymentNote', 'paymentSubmittedAt']);

      // Doctor can only update appointment status
      allow update: if signedIn()
        && resource.data.doctorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']);

      // Patient can cancel a pending appointment
      allow delete: if signedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.status == 'pending';
    }

    match /prescriptions/{id} {
      // Only users with role == 'doctor' can create prescriptions
      allow create: if signedIn()
        && isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && request.resource.data.medicationName is list
        && request.resource.data.dosage is list
        && request.resource.data.medicationName.size() == request.resource.data.dosage.size()
        && request.resource.data.medicationName.size() >= 1
        && request.resource.data.medicationName.size() <= 10;

      // Patient and doctor can read prescriptions
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid
      );

      // Only the prescribing doctor can update (e.g., change status to cancelled)
      allow update: if signedIn() && resource.data.doctorId == request.auth.uid;

      // No deletion of prescriptions (audit trail)
      allow delete: if false;
    }

    match /reminders/{id} {
      // System creates reminders (via Cloud Functions or client)
      allow create: if signedIn() && request.resource.data.userId in [request.auth.uid];

      // Users can only read their own reminders
      allow read: if signedIn() && resource.data.userId == request.auth.uid;

      // Users can update isSent and isRead status only
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isSent', 'isRead', 'sentAt']);

      // No deletion of reminders (audit trail)
      allow delete: if false;
    }
  }
}
