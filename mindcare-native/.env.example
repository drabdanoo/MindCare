# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials
# DO NOT commit .env file to version control!

# Common values
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# If not set, authDomain will default to ${PROJECT_ID}.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Web app credentials (fill these from Firebase Console → Project Settings → Your apps → Web app)
EXPO_PUBLIC_FIREBASE_API_KEY_WEB=your-web-api-key
EXPO_PUBLIC_FIREBASE_APP_ID_WEB=your-web-app-id

# Android app credentials (from google-services.json)
EXPO_PUBLIC_FIREBASE_API_KEY_ANDROID=your-android-api-key
EXPO_PUBLIC_FIREBASE_APP_ID_ANDROID=your-android-app-id